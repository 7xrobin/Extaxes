OPENAI_API_KEY=sk-proj-...
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
AGENT_MODEL=gpt-4o

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Defaults match docker-compose.yml. The Docker container publishes Postgres on
# host port 5433 (5432 is taken by a local Postgres on dev machines).
POSTGRES_DB=investbuddy
POSTGRES_USER=investbuddy
POSTGRES_PASSWORD=investbuddy
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
# Optional: override the LangGraph checkpointer DB (defaults to the same DB above)
# LANGGRAPH_DB_URL=postgresql://investbuddy:investbuddy@localhost:5433/investbuddy

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: DEBUG | INFO | WARNING | ERROR. DJANGO_LOG_LEVEL covers Django's own
# loggers; APP_LOG_LEVEL covers the agent/rag/portfolio/chat/digest apps.
DJANGO_LOG_LEVEL=INFO
APP_LOG_LEVEL=DEBUG

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
# Set LANGSMITH_TRACING=true and provide a key to stream graph runs, tool spans
# and LLM calls to https://smith.langchain.com
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=kyron-investbuddy
